<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_cham_cong_tree" model="ir.ui.view">
            <field name="name">cham_cong.tree</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ngay_cham_cong"/>
                    <field name="nhan_vien_id"/>
                    <field name="gio_vao" widget="float_time"/>
                    <field name="gio_ra" widget="float_time"/>
                    <field name="so_gio_lam"/>
                    <field name="so_cong"/>
                    <field name="di_muon"/>
                    <field name="ve_som"/>
                    <field name="so_gio_tang_ca"/>
                    <field name="tien_phat"/>
                    <field name="trang_thai"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_cham_cong_form" model="ir.ui.view">
            <field name="name">cham_cong.form</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group string="Thông tin cơ bản">
                                <field name="nhan_vien_id"/>
                                <field name="ngay_cham_cong"/>
                                <field name="trang_thai"/>
                            </group>
                            <group string="Giờ làm việc">
                                <field name="gio_vao" widget="float_time"/>
                                <field name="gio_ra" widget="float_time"/>
                                <field name="so_gio_lam"/>
                            </group>
                        </group>
                        <group>
                            <group string="Kết quả tính công">
                                <field name="so_cong"/>
                                <field name="so_gio_tang_ca"/>
                            </group>
                            <group string="Vi phạm">
                                <field name="di_muon"/>
                                <field name="ve_som"/>
                                <field name="tien_phat"/>
                            </group>
                        </group>
                        <group>
                            <field name="ghi_chu"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_cham_cong" model="ir.actions.act_window">
            <field name="name">Chấm công</field>
            <field name="res_model">cham_cong</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
