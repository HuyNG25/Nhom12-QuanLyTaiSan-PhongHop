<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_van_ban_di_tree" model="ir.ui.view">
        <field name="name">quanly.vanbandi.tree</field>
        <field name="model">quanly.vanbandi</field>
        <field name="arch" type="xml">
            <tree>
                <field name="so_hieu"/>
                <field name="tieu_de"/>
                <field name="ngay_di"/>
                <field name="loai_vb_id"/>
                <field name="noi_nhan"/>
            </tree>
        </field>
    </record>

    <record id="view_van_ban_di_form" model="ir.ui.view">
        <field name="name">quanly.vanbandi.form</field>
        <field name="model">quanly.vanbandi</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="so_hieu"/>
                            <field name="tieu_de"/>
                            <field name="ngay_di"/>
                        </group>
                        <group>
                            <field name="loai_vb_id"/>
                            <field name="noi_nhan"/>
                            <field name="nguoi_ky"/>
                            <field name="tep_dinh_kem"/>
                        </group>
                    </group>
                    <group>
                        <field name="noi_dung"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_van_ban_di" model="ir.actions.act_window">
        <field name="name">Văn Bản Đi</field>
        <field name="res_model">quanly.vanbandi</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>