<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loai_van_ban_tree" model="ir.ui.view">
        <field name="name">quanly.loaivanban.tree</field>
        <field name="model">quanly.loaivanban</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ten_loai"/>
                <field name="mo_ta"/>
            </tree>
        </field>
    </record>

    <record id="view_loai_van_ban_form" model="ir.ui.view">
        <field name="name">quanly.loaivanban.form</field>
        <field name="model">quanly.loaivanban</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="ten_loai"/>
                        <field name="mo_ta"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loai_van_ban" model="ir.actions.act_window">
        <field name="name">Loại Văn Bản</field>
        <field name="res_model">quanly.loaivanban</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>